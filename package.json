{
	"name": "vue-spa-template",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"browserslist": "baseline newly available with downstream",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"eslint": "eslint . --quiet",
		"eslint:fix": "eslint . --fix",
		"stylelint": "stylelint \"**/*.{css,scss,vue}\" --quiet",
		"stylelint:fix": "stylelint \"**/*.{css,scss,vue}\" --fix",
		"prettier": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"typecheck": "vue-tsc -b",
		"circular": "dpdm --exit-code circular:1 --no-tree --no-warning --progress false --transform \"./src/main.ts\"",
		"deadcode": "knip --exclude binaries,dependencies,unlisted",
		"check": "run-p typecheck eslint stylelint circular deadcode build",
		"prepare": "husky",
		"format": "npm run eslint:fix && npm run stylelint:fix && npm run prettier:fix"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/vue-query": "^5.92.9",
		"@unhead/vue": "^2.1.12",
		"@vueuse/core": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-vue-next": "^0.577.0",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.17",
		"vee-validate": "^4.15.1",
		"vue": "^3.5.30",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@hey-api/openapi-ts": "^0.94.0",
		"@stylistic/stylelint-plugin": "^5.0.1",
		"@types/node": "^25.4.0",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/tsconfig": "^0.9.0",
		"dotenv": "^17.3.1",
		"dpdm": "^4.0.1",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-security": "^4.0.0",
		"eslint-plugin-unicorn": "^63.0.0",
		"eslint-plugin-vue": "^10.8.0",
		"husky": "^9.1.7",
		"knip": "^5.86.0",
		"npm-run-all": "^4.1.5",
		"postcss-html": "^1.8.1",
		"stylelint": "^17.4.0",
		"stylelint-config-recess-order": "^7.6.1",
		"stylelint-config-recommended-vue": "^1.6.1",
		"stylelint-high-performance-animation": "^2.0.0",
		"stylelint-order": "^7.0.1",
		"stylelint-plugin-logical-css": "^2.0.2",
		"stylelint-plugin-use-baseline": "^1.2.7",
		"stylelint-prettier": "^5.0.3",
		"stylelint-use-nesting": "^6.0.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.0-beta",
		"vite": "^8.0.0-beta.16",
		"vue-tsc": "^3.2.5"
	},
	"overrides": {
		"vite": "^8.0.0-beta.16",
		"typescript": "^6.0.0-beta"
	}
}
